class Solution {
    public int pivotIndex(int[] nums) {
        int r =0,l=0;
        int n =nums.length;
        for(int i=0;i<=n-1;i++){
          r+=nums[i];
        }
        for(int i=0;i<=n-1;i++){
            r-=nums[i];
            if(l==r){
            return i;
        }
        l+=nums[i];
        }
            return -1;
    }
}
