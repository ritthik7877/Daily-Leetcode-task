class Solution {
    public void wiggleSort(int[] nums) {
       Arrays.sort(nums);
       int n = nums.length;
       int w[]=new int[nums.length];
       int a = (n-1)/2;
       int b =n-1;
       for(int i=0;i<nums.length;i++){
        if(i%2==0){
            w[i] = nums[a];
            a--;
        }
        else{
            w[i] = nums[b];
            b--;
        }
       }
       for(int i=0;i<n;i++){
        nums[i] = w[i];
       }
    }
}
